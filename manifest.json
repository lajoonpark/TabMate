{
  "manifest_version": 3,
  "name": "TabSweep",
  "description": "Quickly categorize and close messy tabs by group.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "permissions": ["tabs", "storage"],
  "action": {
    "default_title": "TabSweep",
    "default_popup": "popup.html"
  }
}
