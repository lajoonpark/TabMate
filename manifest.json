{
  "manifest_version": 3,
  "name": "TabSweep",
  "description": "Quickly categorize and close messy tabs by group.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage"],
  "action": {
    "default_title": "TabSweep",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html"
  }
}
